void handleRoot()       { server.send(200, "text/html", htmlContent); }
void handleGetDistance(){ server.send(200, "text/plain", String(getDistance())); }

void setup() {
  Serial.begin(115200);
  if (!WiFi.config(local_IP, gateway, subnet)) Serial.println("Static IP config failed");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  Serial.println("\nWiFi connected — http://192.168.68.100");
  pinMode(triggerPin, OUTPUT);
  pinMode(echoPin, INPUT);
  server.on("/", HTTP_GET, handleRoot);
  server.on("/getDistance", HTTP_GET, handleGetDistance);
  server.begin();
}

void loop() { server.handleClient(); }
